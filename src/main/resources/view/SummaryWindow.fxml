<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.Scene?>
<?import javafx.scene.image.Image?>
<?import javafx.stage.Stage?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.text.TextFlow?>
<?import javafx.scene.layout.VBox?>

<fx:root resizable="false" title="Summary" type="javafx.stage.Stage" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <icons>
    <Image url="@/images/help_icon.png" />
  </icons>
  <scene>
    <Scene width="400">
      <stylesheets>
        <URL value="@SummaryWindow.css" />
      </stylesheets>

      <ScrollPane fitToWidth="true" pannable="true" hbarPolicy="NEVER">
        <content>
            <VBox alignment="CENTER" fx:id="summaryMessageContainer" spacing="10">
            <children>
              <TextFlow fx:id="summaryMessage" lineSpacing="4.0">
                  <padding>
                      <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                  </padding>
              </TextFlow>
            </children>
            <opaqueInsets>
              <Insets bottom="10.0" left="5.0" right="10.0" top="5.0" />
            </opaqueInsets>
            <padding>
              <Insets bottom="10.0" left="5.0" right="10.0" top="5.0" />
            </padding>
          </VBox>
        </content>
      </ScrollPane>
    </Scene>
  </scene>
</fx:root>
